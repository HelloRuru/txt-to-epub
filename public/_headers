# Cloudflare Pages custom headers
# HTML + index 強制不快取（no-store = 連瀏覽器都不存）

/*.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/readmoo-ap/
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/readmoo-ap/*
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/book-manager/
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/post-writer/
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/xtc/*.js
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/xtc/*.css
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

# XTC Flasher: HTML / JS / CSS 不快取（方便更新），bin 檔短快取 + must-revalidate
/xtc-flasher/
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/xtc-flasher/index.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/xtc-flasher/*.js
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/xtc-flasher/*.css
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/xtc-flasher/css/*
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/xtc-flasher/js/*
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/xtc-flasher/firmware/*
  Cache-Control: public, max-age=60, must-revalidate

# API: 短快取
/api/*
  Cache-Control: public, max-age=300
