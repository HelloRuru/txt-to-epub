{
  "manifest_version": 3,
  "name": "讀墨省錢計算機",
  "version": "1.1.0",
  "description": "逛讀墨時自動顯示最划算的購買方式 — 75折券、8折券、領書額度、疊疊樂一目瞭然",
  "author": "HelloRuru",
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://readmoo.com/book/*"],
      "js": ["calc.js", "content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://readmoo.com/cart*"],
      "js": ["calc.js", "cart.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
